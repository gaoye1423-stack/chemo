.tab-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
  }
  
  /* 磨砂玻璃效果 - 复用 navbar 的样式 */
  .tab-bar-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(26, 26, 26, 0.7);  /* 透明度这里调 */
    backdrop-filter: blur(20px);         /* 模糊度这里调 */
    -webkit-backdrop-filter: blur(20px);
    border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  }
  
  .tab-bar-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-around;
    align-items: center;
    height: 100rpx;
  }
  
  .tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
  
  .tab-text {
    font-size: 28rpx;
    color: #999999;
  }
  
  .tab-item.active .tab-text {
    color: #ff6b35;
  }
  
  .safe-area-bottom {
    height: constant(safe-area-inset-bottom);
    height: env(safe-area-inset-bottom);
  }
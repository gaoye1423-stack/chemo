page {
    background-color: #000000;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
    overflow-x: hidden;
    width: 100vw;
  }
  
  .container {
    padding: 0rpx;
    padding-bottom: 60rpx;
    overflow-x: hidden;
    width: 100vw;
    box-sizing: border-box;
  }
  
  .hero-section {
    position: relative;
    margin-bottom: 100rpx;
  }
  
  .hero-swiper {
    height: 900rpx;
    position: relative;
  }
  
  .banner-image {
    width: 100%;
    height: 100%;
    filter: brightness(0.7);
  }
  
  .banner-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 400rpx;
    background: linear-gradient(transparent, #000000);
    pointer-events: none;
  }
  
  .banner-content {
    position: absolute;
    bottom: 180rpx;
    left: 40rpx;
    right: 40rpx;
    z-index: 10;
  }
  
  .banner-tag {
    font-size: 24rpx;
    color: #ff6b35;
    letter-spacing: 4rpx;
    font-weight: 600;
    margin-bottom: 20rpx;
  }
  
  .banner-title {
    font-size: 64rpx;
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 16rpx;
    letter-spacing: -2rpx;
  }
  
  .banner-subtitle {
    font-size: 28rpx;
    color: #aaa;
  }
  
  .warranty-card {
    position: absolute;
    bottom: -60rpx;
    left: 40rpx;
    right: 40rpx;
    background: #1a1a1a;
    border-radius: 28rpx;
    padding: 40rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1rpx solid #2a2a2a;
    box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
    z-index: 20;
  }
  
  .warranty-left {
    display: flex;
    align-items: center;
  }
  
  .warranty-icon-wrap {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 24rpx;
    box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.3);
  }
  
  .warranty-icon {
    font-size: 40rpx;
    color: #000;
    font-weight: bold;
  }
  
  .warranty-title {
    font-size: 32rpx;
    font-weight: 300;
    margin-bottom: 8rpx;
  }
  
  .warranty-desc {
    font-size: 24rpx;
    color: #666;
  }
  
  .warranty-arrow {
    font-size: 36rpx;
    color: #444;
    font-weight: 300;
  }
  
  .action-card {
    margin: 0 40rpx 40rpx;
    background: #1a1a1a;
    border-radius: 28rpx;
    padding: 40rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1rpx solid #2a2a2a;
  }
  
  .action-left {
    display: flex;
    align-items: center;
  }
  
  .action-icon-wrap {
    width: 88rpx;
    height: 88rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 24rpx;
  }
  
  .cases-icon {
    background: rgba(255, 107, 53, 0.1);
    border: 1rpx solid rgba(255, 107, 53, 0.2);
  }
  
  .action-icon {
    font-size: 36rpx;
    color: #ff6b35;
  }
  
  .action-title {
    font-size: 32rpx;
    font-weight: 300;
    margin-bottom: 8rpx;
  }
  
  .action-desc {
    font-size: 24rpx;
    color: #666;
  }
  
  .action-arrow {
    font-size: 36rpx;
    color: #444;
  }
  
  .section-wrapper {
    margin: 100rpx 40rpx 30rpx;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  
  .section-title-text {
    font-size: 48rpx;
    font-weight: 300;
    letter-spacing: -1rpx;
  }
  
  .section-more {
    font-size: 26rpx;
    color: #ff6b35;
    font-weight: 500;
  }
  
  .product-scroll {
    white-space: nowrap;
    padding: 0 40rpx;
  }
  
  .product-card {
    display: inline-block;
    width: 560rpx;
    height: 400rpx;
    border-radius: 32rpx;
    overflow: hidden;
    margin-right: 30rpx;
    position: relative;
    background: #1a1a1a;
    vertical-align: top;
    border: 1rpx solid #2a2a2a;
  }
  
  .product-card:last-child {
    margin-right: 0;
  }
  
  .product-glow {
    position: absolute;
    top: -100rpx;
    right: -100rpx;
    width: 300rpx;
    height: 300rpx;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  
  .product-image {
    width: 100%;
    height: 100%;
    opacity: 0.8;
  }
  
  .product-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40rpx;
    background: linear-gradient(transparent, rgba(0,0,0,0.9));
  }
  
  .product-category {
    font-size: 22rpx;
    color: #ff6b35;
    margin-bottom: 12rpx;
    letter-spacing: 2rpx;
  }
  
  .product-name {
    font-size: 40rpx;
    font-weight: 300;
    margin-bottom: 20rpx;
    white-space: normal;
    line-height: 1.2;
  }
  
  .product-specs {
    display: flex;
    gap: 16rpx;
    flex-wrap: wrap;
  }
  
  .spec-item {
    font-size: 22rpx;
    color: #aaa;
    background: rgba(255,255,255,0.08);
    padding: 10rpx 20rpx;
    border-radius: 8rpx;
    border: 1rpx solid rgba(255,255,255,0.1);
  }
  
  .product-tag {
    position: absolute;
    top: 30rpx;
    right: 30rpx;
    background: #ff6b35;
    color: #000;
    font-size: 20rpx;
    font-weight: 300;
    padding: 10rpx 24rpx;
    border-radius: 100rpx;
  }
  
  .stats-section {
    display: flex;
    justify-content: space-around;
    align-items: center;
    background: #1a1a1a;
    border-radius: 32rpx;
    padding: 50rpx 20rpx;
    margin: 60rpx 40rpx;
    border: 1rpx solid #2a2a2a;
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-number {
    font-size: 56rpx;
    font-weight: 300;
    margin-bottom: 12rpx;
  }
  
  .gradient-text {
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .stat-label {
    font-size: 24rpx;
    color: #666;
  }
  
  .stat-divider {
    width: 2rpx;
    height: 60rpx;
    background: #333;
  }
  
  .case-grid {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
    margin: 0 40rpx;
  }
  
  .case-card {
    position: relative;
    border-radius: 24rpx;
    overflow: hidden;
  }
  
  .case-card.large {
    height: 400rpx;
  }
  
  .case-card.small {
    height: 240rpx;
    flex: 1;
  }
  
  .case-small-grid {
    display: flex;
    gap: 20rpx;
  }
  
  .case-card image {
    width: 100%;
    height: 100%;
    opacity: 0.9;
  }
  
  .case-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30rpx;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
  }
  
  .case-car {
    font-size: 32rpx;
    font-weight: 600;
    margin-bottom: 8rpx;
  }
  
  .case-product {
    font-size: 24rpx;
    color: #ff6b35;
  }
  
  .case-badge {
    position: absolute;
    top: 30rpx;
    left: 30rpx;
    background: rgba(255, 107, 53, 0.9);
    color: #000;
    font-size: 22rpx;
    font-weight: 700;
    padding: 10rpx 24rpx;
    border-radius: 100rpx;
  }
  
  .cta-section {
    background: #1a1a1a;
    border-radius: 32rpx;
    padding: 50rpx 40rpx;
    margin: 60rpx 40rpx 0;
    text-align: center;
    border: 1rpx solid #2a2a2a;
  }
  
  .cta-text {
    font-size: 28rpx;
    color: #888;
    margin-bottom: 30rpx;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    color: #000000;
    font-size: 32rpx;
    font-weight: 600;
    height: 100rpx;
    border-radius: 50rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.3);
  }
  
  .btn-primary:active {
    transform: scale(0.98);
    opacity: 0.9;
  }
page { background: #000; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif; }

.page-container { padding-bottom: 180rpx; }

/* 顶部图片 */
.header-banner { width: 100%; height: 550rpx; position: relative; }
.main-image { width: 100%; height: 100%; }
.image-overlay { 
  position: absolute; bottom: 0; left: 0; right: 0; height: 200rpx;
  background: linear-gradient(to top, #000, transparent);
}
.back-home-btn {
  position: absolute; top: 100rpx; left: 40rpx; width: 70rpx; height: 70rpx;
  background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  border: 1px solid rgba(255,255,255,0.2);
}

/* 内容卡片 */
.content-card { margin-top: -60rpx; position: relative; padding: 40rpx; background: #000; border-radius: 60rpx 60rpx 0 0; }

.tag-row { display: flex; align-items: center; margin-bottom: 20rpx; }
.category-tag { font-size: 20rpx; color: #ff6b35; font-weight: bold; letter-spacing: 2rpx; border: 1px solid #ff6b35; padding: 4rpx 16rpx; border-radius: 8rpx; }
.hot-badge { background: #ff4d4f; color: #fff; font-size: 18rpx; padding: 4rpx 12rpx; border-radius: 6rpx; margin-left: 20rpx; }

.title-section { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30rpx; }
.product-name { font-size: 48rpx; font-weight: 600; flex: 1; padding-right: 20rpx; }
.price-box { text-align: right; color: #ff6b35; }
.price-num { font-size: 52rpx; font-weight: bold; }
.symbol { font-size: 28rpx; margin-right: 4rpx; }
.unit { font-size: 24rpx; color: #666; margin-left: 6rpx; }

.product-desc { font-size: 28rpx; color: #999; line-height: 1.6; display: block; }

/* 参数区域 */
.specs-title { display: flex; align-items: center; justify-content: center; margin: 60rpx 0 30rpx; }
.specs-title .line { width: 40rpx; height: 1px; background: #333; }
.specs-title .txt { font-size: 24rpx; color: #666; margin: 0 20rpx; letter-spacing: 4rpx; }

.specs-grid { display: flex; gap: 20rpx; }
.spec-item { flex: 1; background: #111; border-radius: 24rpx; padding: 30rpx 10rpx; border: 1px solid #222; position: relative; overflow: hidden; }
.spec-inner { position: relative; z-index: 1; text-align: center; }
.spec-val { display: block; font-size: 36rpx; font-weight: bold; color: #fff; margin-bottom: 8rpx; }
.spec-lab { font-size: 22rpx; color: #555; }

/* 服务条 */
.service-bar { display: flex; justify-content: space-between; background: #0a0a0a; padding: 24rpx 40rpx; border-radius: 20rpx; margin-top: 40rpx; }
.service-item { display: flex; align-items: center; font-size: 22rpx; color: #888; }
.service-item text { margin-left: 10rpx; }

/* 详情图片区域优化 */
.detail-section { margin-top: 20rpx; } /* 增加一点与服务条的间距 */

.section-head { 
  font-size: 32rpx; 
  font-weight: bold; 
  margin: 50rpx 0; /* 核心修改：大幅减小上下间距，紧贴图片 */
  padding-left: 20rpx; 
  border-left: 6rpx solid #ff6b35; 
}

.detail-imgs { width: 100%; }

.detail-long-img { 
  width: 100%; 
  border-radius: 20rpx; 
  margin-bottom: 10rpx; /* 图片之间的间距 */
  display: block; /* 消除图片下方的空隙 */
}

.footer-note { text-align: center; color: #333; font-size: 24rpx; padding: 60rpx 0; }

/* 底部栏 */
.glass-footer {
  position: fixed; bottom: 40rpx; left: 30rpx; right: 30rpx; height: 120rpx;
  background: rgba(20, 20, 20, 0.85); backdrop-filter: blur(20px);
  border-radius: 100rpx; display: flex; align-items: center; padding: 0 10rpx 0 40rpx;
  border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 20rpx 50rpx rgba(0,0,0,0.5);
}
.footer-left { display: flex; gap: 40rpx; }
.nav-icon-btn { 
  display: flex; flex-direction: column; align-items: center; background: none; 
  padding: 0; margin: 0; line-height: 1; width: auto; color: #888; font-size: 20rpx;
}
.nav-icon-btn .dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: #444; margin-bottom: 10rpx; }
.nav-icon-btn .dot.orange { background: #ff6b35; }

.footer-right { flex: 1; display: flex; justify-content: flex-end; }
.order-btn {
  background: linear-gradient(135deg, #ff8c5a, #ff6b35);
  color: #000; font-size: 28rpx; font-weight: bold;
  height: 100rpx; line-height: 100rpx; border-radius: 50rpx;
  width: 320rpx; margin: 0;
}
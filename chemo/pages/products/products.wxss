page {
    background-color: #000000;
    color: #ffffff;
  }
  
  .container {
    padding: 0;
    padding-bottom: 180rpx;
  }
  
  /* ===== 头部纯文字区域优化 ===== */
  .header-text-section {
    width: 100%;
    background-color: #000000;
    padding: 60rpx 30rpx 40rpx; /* 增加上下内边距，让文字居中感更强 */
    box-sizing: border-box;
  }
  
  .banner-content {
    display: flex;
    flex-direction: column;
  }
  
  .banner-tag {
    font-size: 24rpx;
    color: #ff6b35;
    letter-spacing: 4rpx;
    font-weight: 600;
    margin-bottom: 16rpx;
  }
  
  .banner-title {
    font-size: 56rpx; /* 稍微放大一点，因为没有图片背景了，标题需要更有张力 */
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 12rpx;
    color: #ffffff;
  }
  
  .banner-subtitle {
    font-size: 28rpx;
    color: #888;
  }
  
  /* ===== 吸顶逻辑修正 ===== */
  .sticky-box {
    position: -webkit-sticky;
    position: sticky;
    top: 0; 
    z-index: 100;
    background-color: #000;
    padding: 20rpx 0;
    /* 去掉了之前的 margin-top 负边距 */
  }
  
  .series-tabs-float {
    display: flex;
    margin: 0 30rpx;
    gap: 20rpx;
  }
  
  .tab-item-float {
    flex: 1;
    padding: 22rpx 0;
    background: #1a1a1a;
    border-radius: 100rpx;
    font-size: 28rpx;
    color: #999;
    text-align: center;
    border: 1rpx solid #2a2a2a;
    transition: all 0.3s;
  }
  
  .tab-item-float.active {
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    color: #000;
    font-weight: 600;
    border-color: transparent;
  }
  
  /* ===== 产品列表保持原样优化 ===== */
  .product-list {
    padding: 20rpx 30rpx;
  }
  
  .product-card-large {
    background: #111111; /* 稍微深一点的黑色，与背景区分 */
    border-radius: 24rpx;
    overflow: hidden;
    margin-bottom: 30rpx;
    border: 1rpx solid #222222;
  }
  
  .product-image-wrap {
    position: relative;
    width: 100%;
    height: 380rpx;
  }
  
  .product-image-large {
    width: 100%;
    height: 100%;
  }
  
  .product-content {
    padding: 30rpx;
  }
  
  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16rpx;
  }
  
  .product-tag-large {
    font-size: 22rpx;
    color: #ff6b35;
  }
  
  .product-price {
    display: flex;
    align-items: baseline;
    color: #ff6b35;
  }
  
  .price-num {
    font-size: 44rpx;
    font-weight: 700;
  }
  
  .product-name-large {
    font-size: 38rpx;
    font-weight: 600;
    margin-bottom: 12rpx;
  }
  
  .product-desc {
    font-size: 24rpx;
    color: #888;
    margin-bottom: 30rpx;
  }
  
  .specs-grid {
    display: flex;
    justify-content: space-around;
    padding: 24rpx;
    background: #080808;
    border-radius: 12rpx;
    margin-bottom: 30rpx;
  }
  
  .spec-value {
    display: block;
    font-size: 32rpx;
    font-weight: 600;
    color: #fff;
    text-align: center;
  }
  
  .spec-label {
    display: block;
    font-size: 20rpx;
    color: #666;
    text-align: center;
    margin-top: 4rpx;
  }
  
  .car-model-section {
    margin-bottom: 30rpx;
  }
  
  .section-label {
    font-size: 22rpx;
    color: #666;
    margin-bottom: 16rpx;
  }
  
  .model-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
  }
  
  .model-tag {
    padding: 12rpx 28rpx;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8rpx;
    font-size: 24rpx;
    color: #aaa;
  }
  
  .model-tag.active {
    background: rgba(255, 107, 53, 0.2);
    color: #ff6b35;
  }
  
  .product-action {
    display: flex;
    gap: 20rpx;
  }
  
  .btn-consult {
    flex: 1;
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    color: #000;
    border-radius: 44rpx;
    font-size: 30rpx;
    font-weight: 600;
    height: 88rpx;
    line-height: 88rpx;
  }
  
  .btn-favorite {
    width: 88rpx;
    height: 88rpx;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
  }
  
  .btn-favorite.active {
    color: #ff6b35;
  }
page {
    background-color: #000000;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
  }
  
  .container {
    padding-top: 180rpx;
    padding-bottom: 200rpx;
  }
  
  .user-profile-section {
    padding: 0 40rpx;
    margin-bottom: 40rpx;
  }
  
  .user-card-main {
    background: #1a1a1a;
    border-radius: 32rpx;
    padding: 46rpx 40rpx;
    display: flex;
    align-items: center;
    border: 1rpx solid #2a2a2a;
  }
  
  .avatar-wrap {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    border: 2rpx solid #ff6b35;
    overflow: hidden;
    margin-right: 24rpx;
    background: #222;
  }
  
  .avatar-wrap image { width: 100%; height: 100%; }
  
  .user-name { font-size: 36rpx; font-weight: 500; margin-bottom: 8rpx; }
  .user-code { font-size: 24rpx; color: #666; }
  .user-arrow { margin-left: auto; color: #333; font-size: 32rpx; }
  
  .stats-section {
    display: flex;
    justify-content: space-around;
    align-items: center;
    background: #1a1a1a;
    border-radius: 32rpx;
    padding: 50rpx 20rpx;
    margin: 0 40rpx 60rpx;
    border: 1rpx solid #2a2a2a;
  }
  
  .stat-item { text-align: center; }
  .stat-number { font-size: 52rpx; font-weight: 300; margin-bottom: 10rpx; }
  .gradient-text {
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    background-clip: text;            /* 👈 加上这一行标准属性 */
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .stat-label { font-size: 24rpx; color: #666; }
  .stat-divider { width: 2rpx; height: 50rpx; background: #2a2a2a; }
  
  .section-wrapper { margin: 0 40rpx 30rpx; }
  .section-title-text { font-size: 44rpx; font-weight: 300; letter-spacing: 2rpx; }
  
  .menu-list { padding: 0 40rpx; }
  .action-card {
    background: #1a1a1a;
    border-radius: 28rpx;
    padding: 36rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1rpx solid #2a2a2a;
    margin-bottom: 20rpx;
  }
  .highlight-border { border: 1rpx solid rgba(255, 107, 53, 0.3); }
  
  .action-left { display: flex; align-items: center; }
  .action-icon-wrap {
    width: 80rpx; height: 80rpx;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-right: 24rpx;
  }
  .active-bg { background: #ff6b35; }
  .gray-bg { background: rgba(255,255,255,0.05); }
  .action-icon { font-size: 36rpx; color: #000; }
  .gray-bg .action-icon { color: #ff6b35; font-size: 32rpx; }
  
  .action-title { font-size: 32rpx; font-weight: 400; margin-bottom: 6rpx; }
  .action-desc { font-size: 22rpx; color: #555; }
  .action-arrow-text { font-size: 22rpx; color: #ff6b35; }
  .action-arrow { font-size: 32rpx; color: #333; }
  
  .logout-btn {
    text-align: center;
    font-size: 26rpx;
    color: #444;
    margin-top: 80rpx;
    padding-bottom: 40rpx;
  }
  /* --- 追加：自定义登录弹窗样式 --- */
.login-mask {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(20rpx); /* 磨砂效果 */
    display: flex; align-items: center; justify-content: center;
    z-index: 10000;
  }
  
  .login-panel {
    width: 620rpx;
    background: #1a1a1a;
    border: 1rpx solid #2a2a2a;
    border-radius: 40rpx;
    overflow: hidden;
    box-shadow: 0 40rpx 100rpx rgba(0,0,0,0.8);
    animation: modalShow 0.3s ease-out;
  }
  
  @keyframes modalShow {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }
  
  .login-header {
    padding: 60rpx 40rpx 40rpx;
    text-align: center;
  }
  
  .login-title {
    font-size: 36rpx;
    font-weight: 500;
    color: #fff;
    margin-bottom: 16rpx;
  }
  
  .login-subtitle {
    font-size: 26rpx;
    color: #666;
    line-height: 1.5;
  }
  
  .login-body {
    padding: 0 50rpx 60rpx;
  }
  
  .input-group {
    background: #000;
    border: 1rpx solid #333;
    border-radius: 20rpx;
    height: 100rpx;
    display: flex;
    align-items: center;
    padding: 0 30rpx;
  }
  
  .my-input {
    flex: 1;
    height: 100rpx;
    color: #ff6b35; /* 输入文字颜色 */
    font-size: 32rpx;
  }
  
  .ph-color { color: #333; }
  
  .login-footer {
    display: flex;
    border-top: 1rpx solid #2a2a2a;
  }
  
  .login-footer view {
    flex: 1;
    height: 110rpx;
    line-height: 110rpx;
    text-align: center;
    font-size: 30rpx;
  }
  
  .btn-cancel {
    color: #666;
    border-right: 1rpx solid #2a2a2a;
  }
  
  .btn-submit {
    color: #ff6b35;
    font-weight: bold;
    background: rgba(255, 107, 53, 0.05);
  }
<navbar title="电子质保详情" back="{{true}}" />

<view class="container" wx:if="{{!loading && info}}">
  <view class="header">
    <view class="success-wrap"><icon type="success" size="60" color="#ff6b35"></icon></view>
    <view class="title">正品电子质保凭证</view>
    <view class="sn">记录编号：{{info._id}}</view>
  </view>

  <view class="info-card">
    <view class="card-title">车主及车辆信息</view>
    <view class="item"><text class="label">车牌号码</text><text class="value">{{info.carPlate}}</text></view>
    <view class="item"><text class="label">车主姓名</text><text class="value">{{info.ownerName}}</text></view>
    <view class="item"><text class="label">手机号码</text><text class="value">{{info.ownerPhone}}</text></view>
    <view class="item"><text class="label">车架号(VIN)</text><text class="value">{{info.vin}}</text></view>
  </view>

  <view class="info-card">
    <view class="card-title">产品及质保信息</view>
    <view class="item"><text class="label">产品类型</text><text class="value highlight">{{info.productType}}</text></view>
    
    <block wx:if="{{info.productType !== '太阳膜'}}">
      <view class="item"><text class="label">产品系列</text><text class="value">{{info.productSeries || '官方正品系列'}}</text></view>
      <view class="item"><text class="label">SN序列号</text><text class="value">{{info.snCode}}</text></view>
    </block>

    <view class="solar-box" wx:if="{{info.productType === '太阳膜' && info.productDetails.length > 0}}">
      <view class="detail-row" wx:for="{{info.productDetails}}" wx:key="part">
        <view class="part-header">
          <view class="part-name">{{item.part}}</view>
          <view class="part-price" wx:if="{{item.price}}">￥{{item.price}}</view>
        </view>
        <view class="part-val">系列: {{item.series}} | SN: {{item.sn}}</view>
      </view>
    </view>

    <view class="item"><text class="label">质保年限</text><text class="value">{{info.warrantyYear}}年</text></view>
    <view class="item" wx:if="{{info.productPrice}}"><text class="label">施工价格</text><text class="value price-tag">￥{{info.productPrice}}</text></view>
  </view>

  <view class="info-card">
    <view class="card-title">施工详情</view>
    <view class="item"><text class="label">施工门店</text><text class="value">{{info.storeName}}</text></view>
    <view class="item"><text class="label">施工技师</text><text class="value">{{info.technician || '专业技师'}}</text></view>
    <view class="item"><text class="label">施工日期</text><text class="value">{{info.constructDate}}</text></view>
  </view>

  <view class="photo-section" wx:if="{{info.imagePhotos && info.imagePhotos.length > 0}}">
    <view class="card-title">施工图集</view>
    <view class="img-grid">
      <image 
        wx:for="{{info.imagePhotos}}" 
        wx:key="index" 
        src="{{item}}" 
        mode="aspectFill" 
        bindtap="previewImage" 
        data-url="{{item}}"
      ></image>
    </view>
  </view>

  <view class="info-card" wx:if="{{info.remark}}">
    <view class="card-title">备注说明</view>
    <view class="remark-content">{{info.remark}}</view>
  </view>

  <view class="footer-seal">
    <view class="seal-text">官方电子档案已备案</view>
    <view class="timestamp">备案时间：{{displayTime}}</view>
  </view>
</view>
<navbar title="质保查询"/>

<view class="container">
  <view class="hero-header text-center">
    <view class="banner-tag">OFFICIAL WARRANTY</view>
    <view class="banner-title">官方正品 权益保障</view>
    <view class="banner-subtitle">为每一台爱车建立数字化防护档案</view>
    <view class="header-glow"></view>
  </view>

  <view class="query-card">
    <view class="card-inner-title">质保信息查询</view>
    
    <view class="input-group">
      <view class="input-item">
        <text class="input-label">车牌号码</text>
        <input 
          placeholder="请输入车牌号" 
          placeholder-class="ph-color" 
          bindinput="onInput" 
          data-field="carPlate" 
          value="{{carPlate}}"
        />
      </view>
      <view class="input-item">
        <text class="input-label">手机号码</text>
        <input 
          type="number" 
          placeholder="请输入预留手机号" 
          placeholder-class="ph-color" 
          bindinput="onInput" 
          data-field="ownerPhone" 
          value="{{ownerPhone}}"
        />
      </view>
      <view class="input-item">
        <text class="input-label">质保单号</text>
        <input 
          placeholder="请输入质保编号(选填)" 
          placeholder-class="ph-color" 
          bindinput="onInput" 
          data-field="warrantyId" 
          value="{{warrantyId}}"
        />
      </view>
    </view>

    <button class="btn-primary" bindtap="onSearch">立即查询</button>
  </view>

  <view class="section-wrapper text-center">
    <view class="section-title-text">服务承诺</view>
  </view>

  <view class="rights-list">
    <view class="right-card" wx:for="{{rightsList}}" wx:key="index">
      <view class="right-icon-wrap">
        <text class="right-icon">{{item.icon}}</text>
      </view>
      <view class="right-content">
        <view class="right-title">{{item.title}}</view>
        <view class="right-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="footer-note">
    * 如无法查询到信息，请联系施工门店核实质保上传状态
  </view>
</view>

<tabbar selected="2"/>
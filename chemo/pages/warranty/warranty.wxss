page {
    background-color: #000000;
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
  }
  
  .container {
    padding: 0 0 140rpx;
  }
  
  /* ===== 1. 头部 Slogan - 完全居中版 ===== */
  .hero-header.text-center {
    position: relative;
    padding: 120rpx 40rpx 160rpx; /* 稍微增加间距增加呼吸感 */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;    /* 水平居中 */
    justify-content: center;/* 垂直居中 */
    text-align: center;
  }
  
  .header-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500rpx;
    height: 500rpx;
    background: radial-gradient(circle, rgba(255, 107, 53, 0.15) 0%, transparent 70%);
    z-index: 1;
    pointer-events: none;
  }
  
  .banner-tag {
    position: relative;
    z-index: 2;
    font-size: 24rpx;
    color: #ff6b35;
    letter-spacing: 8rpx; /* 更宽的字间距显得更高级 */
    font-weight: 600;
    margin-bottom: 24rpx;
  }
  
  .banner-title {
    position: relative;
    z-index: 2;
    font-size: 56rpx;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 24rpx;
    letter-spacing: 2rpx;
  }
  
  .banner-subtitle {
    position: relative;
    z-index: 2;
    font-size: 26rpx;
    color: #888;
    max-width: 80%;
    line-height: 1.6;
  }
  
  /* ===== 2. 查询卡片 - 维持高水准视觉 ===== */
  .query-card {
    margin: -60rpx 40rpx 60rpx;
    background: #1a1a1a;
    border-radius: 32rpx;
    padding: 50rpx 40rpx;
    border: 1rpx solid #2a2a2a;
    box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
    position: relative;
    z-index: 10;
  }
  
  .card-inner-title {
    font-size: 32rpx;
    color: #ff6b35;
    margin-bottom: 40rpx;
    font-weight: 400;
    text-align: center; /* 查询标题也设为居中 */
  }
  
  .input-item {
    margin-bottom: 30rpx;
    border-bottom: 1rpx solid #2a2a2a;
    padding-bottom: 16rpx;
  }
  
  .input-label {
    font-size: 22rpx;
    color: #444;
    display: block;
    margin-bottom: 8rpx;
    text-transform: uppercase;
  }
  
  .input-item input {
    height: 60rpx;
    font-size: 30rpx;
    color: #fff;
  }
  
  .ph-color {
    color: #333;
  }
  
  /* ===== 3. 查询按钮 - 添加呼吸灯跳动动画 ===== */
  .btn-primary {
    margin-top: 40rpx;
    background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
    color: #000000;
    font-size: 30rpx;
    font-weight: 600;
    height: 90rpx;
    border-radius: 45rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    /* 呼吸灯动画效果 */
    animation: button-pulse 2s infinite;
  }
  
  @keyframes button-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(255, 107, 53, 0.4);
      transform: scale(1);
    }
    50% {
      box-shadow: 0 0 30rpx 10rpx rgba(255, 107, 53, 0.2);
      transform: scale(1.02); /* 微弱的跳动感 */
    }
    100% {
      box-shadow: 0 0 0 0 rgba(255, 107, 53, 0.4);
      transform: scale(1);
    }
  }
  
  .btn-primary:active {
    transform: scale(0.98);
    opacity: 0.9;
  }
  
  /* ===== 4. 服务承诺 - 整体居中重构 ===== */
  .section-wrapper {
    margin: 60rpx 40rpx 40rpx;
    text-align: center; /* 标题居中 */
  }
  
  .section-title-text {
    font-size: 40rpx;
    font-weight: 300;
    letter-spacing: 2rpx;
  }
  
  .rights-list {
    padding: 0 40rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .right-card {
    display: flex;
    flex-direction: column; /* 改为垂直排列以实现完全居中 */
    align-items: center;
    text-align: center;
    background: #1a1a1a;
    border: 1rpx solid #2a2a2a;
    padding: 40rpx 30rpx;
    border-radius: 24rpx;
    margin-bottom: 24rpx;
    width: 100%;
    box-sizing: border-box;
  }
  
  .right-icon-wrap {
    width: 88rpx;
    height: 88rpx;
    background: rgba(255, 107, 53, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20rpx; /* 图标下方留白 */
    margin-right: 0;      /* 清除原有的右边距 */
  }
  
  .right-icon {
    color: #ff6b35;
    font-size: 32rpx;
  }
  
  .right-title {
    font-size: 30rpx;
    margin-bottom: 10rpx;
    font-weight: 500;
  }
  
  .right-desc {
    font-size: 24rpx;
    color: #666;
    line-height: 1.5;
  }
  
  .footer-note {
    text-align: center;
    color: #333;
    font-size: 22rpx;
    margin-top: 80rpx;
    padding: 0 60rpx;
  }